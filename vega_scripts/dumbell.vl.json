{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "params": [
    {
      "name": "startYearInput",
      "value": 2000,
      "bind": {
        "input": "range",
        "min": 2000,
        "max": 2023,
        "step": 1,
        "name": "START YEAR: "
      }
    },
    {
      "name": "endYearInput",
      "value": 2023,
      "bind": {
        "input": "range",
        "min": 2000,
        "max": 2023,
        "step": 1,
        "name": "END YEAR:   "
      }
    },
    {
      "name": "startYear",
      "expr": "startYearInput == endYearInput ? (startYearInput == 2000 ? 2000 : startYearInput - 1) : min(startYearInput, endYearInput)"
    },
    {
      "name": "endYear",
      "expr": "startYearInput == endYearInput ? (endYearInput == 2000 ? 2001 : endYearInput) : max(startYearInput, endYearInput)"
    }
  ],
  "width": 420,
  "height": 330,
  "title": {
    "text": "Biggest gains",
    "subtitle": [
      "Largest renewable share increase"
    ],
    "anchor": "middle"
  },
  "data": {
    "url": "../data/results/data/energy_improver_pairs.csv",
    "format": {
      "type": "csv",
      "parse": {
        "start_year": "number",
        "end_year": "number",
        "renewables_share_energy_start": "number",
        "renewables_share_energy_end": "number",
        "renewables_share_energy_change": "number"
      }
    }
  },
  "transform": [
    {
      "filter": "datum.start_year == min(startYear, endYear) && datum.end_year == max(startYear, endYear)"
    },
    {
      "window": [
        {
          "op": "rank",
          "as": "rank"
        }
      ],
      "sort": [
        {
          "field": "renewables_share_energy_change",
          "order": "descending"
        }
      ]
    },
    {
      "filter": "datum.rank <= 10"
    },
    {
      "calculate": "(datum.renewables_share_energy_change >= 0 ? '+' : '') + format(datum.renewables_share_energy_change, '.0f') + ' pts'",
      "as": "change_label"
    },
    {
      "fold": [
        "renewables_share_energy_start",
        "renewables_share_energy_end"
      ],
      "as": [
        "year_type",
        "value"
      ]
    },
    {
      "calculate": "datum.year_type === 'renewables_share_energy_start' ? 'start' : 'end'",
      "as": "year_label"
    }
  ],
  "encoding": {
    "y": {
      "field": "country",
      "type": "nominal",
      "sort": {
        "field": "renewables_share_energy_change",
        "order": "descending"
      },
      "title": null,
      "axis": {
        "labels": false,
        "ticks": false,
        "domain": false,
        "labelFontWeight": "normal"
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "fontSize": 11,
        "color": "#333333",
        "fontWeight": "normal"
      },
      "encoding": {
        "x": {
          "value": 0
        },
        "y": {
          "field": "country",
          "type": "nominal",
          "sort": {
            "field": "renewables_share_energy_change",
            "order": "descending"
          }
        },
        "text": {
          "field": "country"
        }
      }
    },
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 1.2,
        "color": "#D9D9D9"
      },
      "encoding": {
        "x": {
          "field": "renewables_share_energy_start",
          "type": "quantitative",
          "scale": {
            "domain": [
              -35,
              65
            ]
          },
          "title": null,
          "axis": {
            "labels": false,
            "ticks": false,
            "domain": false,
            "grid": false
          }
        },
        "x2": {
          "field": "renewables_share_energy_end"
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 70
      },
      "encoding": {
        "x": {
          "field": "value",
          "type": "quantitative"
        },
        "color": {
          "field": "year_label",
          "type": "nominal",
          "scale": {
            "domain": [
              "start",
              "end"
            ],
            "range": [
              "#A0A0A0",
              "#2E7D57"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "country",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "start_year",
            "type": "quantitative",
            "title": "Start year",
            "format": ".0f"
          },
          {
            "field": "renewables_share_energy_start",
            "type": "quantitative",
            "format": ".1f",
            "title": "Start value (%)"
          },
          {
            "field": "end_year",
            "type": "quantitative",
            "title": "End year",
            "format": ".0f"
          },
          {
            "field": "renewables_share_energy_end",
            "type": "quantitative",
            "format": ".1f",
            "title": "End value (%)"
          },
          {
            "field": "renewables_share_energy_change",
            "type": "quantitative",
            "format": ".1f",
            "title": "Change (pp)"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 22,
        "fontSize": 11,
        "color": "#2E7D57",
        "fontWeight": "normal"
      },
      "encoding": {
        "x": {
          "field": "renewables_share_energy_end",
          "type": "quantitative"
        },
        "text": {
          "field": "change_label"
        }
      }
    }
  ],
  "config": {
    "background": "white",
    "view": {
      "stroke": null
    },
    "font": "Inter, Arial, sans-serif",
    "title": {
      "anchor": "start",
      "fontSize": 18,
      "fontWeight": "bold",
      "color": "#1F2933",
      "subtitleFontSize": 11,
      "subtitleColor": "#5F6B66",
      "offset": 8
    },
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "domainColor": "#B8C0BC",
      "tickColor": "#B8C0BC",
      "gridColor": "#E9ECEA",
      "labelColor": "#1F2933",
      "titleColor": "#1F2933"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "labelColor": "#1F2933",
      "titleColor": "#1F2933"
    }
  }
}
