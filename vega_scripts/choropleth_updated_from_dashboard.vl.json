{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 1200,
  "height": 520,
  "title": {
    "text": "Fossil-fuel reduction by country",
    "anchor": "middle",
    "dx": 60
  },
  "projection": {
    "type": "equalEarth"
  },
  "layer": [
    {
      "data": {
        "url": "https://vega.github.io/vega-datasets/data/world-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#F1F1F1",
        "stroke": "white",
        "strokeWidth": 0.25
      }
    },
    {
      "data": {
        "url": "https://vega.github.io/vega-datasets/data/world-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "transform": [
        {
          "lookup": "id",
          "from": {
            "data": {
              "url": "../data/results/data/energy_fossil_reduction_map.csv",
              "format": {
                "type": "csv",
                "parse": {
                  "iso_numeric": "number",
                  "fossil_share_energy_start": "number",
                  "fossil_share_energy_latest": "number",
                  "fossil_reduction": "number",
                  "renewables_share_energy_latest": "number",
                  "population_latest": "number",
                  "start_year": "number",
                  "latest_year": "number"
                }
              }
            },
            "key": "iso_numeric",
            "fields": [
              "country",
              "iso_code",
              "start_year",
              "latest_year",
              "fossil_share_energy_start",
              "fossil_share_energy_latest",
              "fossil_reduction",
              "renewables_share_energy_latest",
              "population_latest"
            ]
          }
        },
        {
          "filter": "isValid(datum.fossil_reduction)"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 0.25
      },
      "encoding": {
        "color": {
          "field": "fossil_reduction",
          "type": "quantitative",
          "title": "Reduction (percentage points)",
          "scale": {
            "scheme": "greens"
          },
          "legend": {
            "orient": "right",
            "direction": "vertical",
            "gradientLength": 360,
            "gradientThickness": 16,
            "titleOrient": "left",
            "labelFontSize": 12,
            "titleFontSize": 12,
            "titleColor": "#1F2933",
            "labelColor": "#1F2933",
            "offset": 8
          }
        },
        "tooltip": [
          {
            "field": "country",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "fossil_share_energy_start",
            "type": "quantitative",
            "format": ".1f",
            "title": "Fossil share in 2000 (%)"
          },
          {
            "field": "fossil_share_energy_latest",
            "type": "quantitative",
            "format": ".1f",
            "title": "Latest fossil share (%)"
          },
          {
            "field": "fossil_reduction",
            "type": "quantitative",
            "format": "+.1f",
            "title": "Reduction"
          },
          {
            "field": "renewables_share_energy_latest",
            "type": "quantitative",
            "format": ".1f",
            "title": "Latest renewables share (%)"
          }
        ]
      }
    }
  ],
  "config": {
    "background": "white",
    "view": {
      "stroke": null
    },
    "font": "Inter, Arial, sans-serif",
    "title": {
      "anchor": "start",
      "fontSize": 18,
      "fontWeight": "bold",
      "color": "#1F2933",
      "subtitleFontSize": 11,
      "subtitleColor": "#5F6B66",
      "offset": 8
    },
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "domainColor": "#B8C0BC",
      "tickColor": "#B8C0BC",
      "gridColor": "#E9ECEA",
      "labelColor": "#1F2933",
      "titleColor": "#1F2933"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "labelColor": "#1F2933",
      "titleColor": "#1F2933"
    }
  }
}
