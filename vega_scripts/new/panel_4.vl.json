{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "params": [
    {
      "name": "startYear",
      "value": 2000,
      "bind": {
        "input": "range",
        "min": 2000,
        "max": 2023,
        "step": 1,
        "name": "Start year: "
      }
    },
    {
      "name": "endYear",
      "value": 2023,
      "bind": {
        "input": "range",
        "min": 2000,
        "max": 2023,
        "step": 1,
        "name": "End year: "
      }
    }
  ],
  "width": 860,
  "height": 260,
  "title": {
    "text": "How has the transition evolved over time?",
    "subtitle": [
      "Selected leaders, an improver, a home-country reference, and large economies over the chosen time window.",
      "Direct labels stay attached to the selected end year."
    ]
  },
  "data": {
    "url": "../../data/results/data/energy_story_countries.csv",
    "format": {
      "type": "csv",
      "parse": {
        "year": "number",
        "clean_share_elec": "number",
        "fossil_share_elec": "number",
        "transition_gap": "number"
      }
    }
  },
  "transform": [
    {
      "filter": "datum.year >= min(startYear, endYear) && datum.year <= max(startYear, endYear)"
    },
    {
      "calculate": "datum.clean_share_elec - datum.fossil_share_elec",
      "as": "transition_gap"
    }
  ],
  "layer": [
    {
      "data": {
        "values": [
          {
            "transition_gap": 0
          }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#A0A0A0"
      },
      "encoding": {
        "y": {
          "field": "transition_gap",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "title": "Year"
        },
        "y": {
          "field": "transition_gap",
          "type": "quantitative",
          "title": "Clean electricity share minus fossil share (pp)"
        },
        "color": {
          "field": "country",
          "type": "nominal",
          "scale": {
            "domain": [
              "Iceland",
              "Norway",
              "Sweden",
              "Denmark",
              "Ireland",
              "India"
            ],
            "range": [
              "#1F77B4",
              "#2CA02C",
              "#9467BD",
              "#FF7F0E",
              "#D62728",
              "#8C564B"
            ]
          },
          "legend": null
        },
        "detail": {
          "field": "country"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year >= min(startYear, endYear) && datum.year <= max(startYear, endYear)"
        },
        {
          "joinaggregate": [
            {
              "op": "max",
              "field": "year",
              "as": "last_year"
            }
          ],
          "groupby": [
            "country"
          ]
        },
        {
          "filter": "datum.year == datum.last_year"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 40
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative"
        },
        "y": {
          "field": "transition_gap",
          "type": "quantitative"
        },
        "color": {
          "field": "country",
          "type": "nominal",
          "scale": {
            "domain": [
              "Iceland",
              "Norway",
              "Sweden",
              "Denmark",
              "Ireland",
              "India"
            ],
            "range": [
              "#1F77B4",
              "#2CA02C",
              "#9467BD",
              "#FF7F0E",
              "#D62728",
              "#8C564B"
            ]
          },
          "legend": null
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year >= min(startYear, endYear) && datum.year <= max(startYear, endYear)"
        },
        {
          "joinaggregate": [
            {
              "op": "max",
              "field": "year",
              "as": "last_year"
            }
          ],
          "groupby": [
            "country"
          ]
        },
        {
          "filter": "datum.year == datum.last_year"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 5,
        "fontSize": 9
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative"
        },
        "y": {
          "field": "transition_gap",
          "type": "quantitative"
        },
        "text": {
          "field": "country"
        },
        "color": {
          "field": "country",
          "type": "nominal",
          "scale": {
            "domain": [
              "Iceland",
              "Norway",
              "Sweden",
              "Denmark",
              "Ireland",
              "India"
            ],
            "range": [
              "#1F77B4",
              "#2CA02C",
              "#9467BD",
              "#FF7F0E",
              "#D62728",
              "#8C564B"
            ]
          },
          "legend": null
        }
      }
    }
  ],
  "config": {
    "background": "white",
    "view": {
      "stroke": null
    },
    "font": "Inter, Arial, sans-serif",
    "title": {
      "anchor": "start",
      "fontSize": 18,
      "fontWeight": "normal",
      "subtitleFontSize": 11,
      "subtitleColor": "#666",
      "offset": 8
    },
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "domainColor": "#999",
      "tickColor": "#999",
      "gridColor": "#E6E6E6",
      "labelColor": "#333",
      "titleColor": "#333"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "labelColor": "#333",
      "titleColor": "#333"
    }
  }
}