{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": {
    "text": "Global Energy Transition",
    "subtitle": [
      "Use the highlighted year sliders to compare at least a one-year transition window."
    ],
    "anchor": "middle",
    "fontSize": 34,
    "fontWeight": "bold",
    "color": "#163225",
    "subtitleFontSize": 14,
    "subtitleColor": "#5F6B66",
    "offset": 14
  },
  "params": [
    {
      "name": "startYearInput",
      "value": 2000,
      "bind": {
        "input": "range",
        "min": 2000,
        "max": 2023,
        "step": 1,
        "name": "START YEAR: "
      }
    },
    {
      "name": "endYearInput",
      "value": 2023,
      "bind": {
        "input": "range",
        "min": 2000,
        "max": 2023,
        "step": 1,
        "name": "END YEAR:   "
      }
    },
    {
      "name": "startYear",
      "expr": "startYearInput == endYearInput ? (startYearInput == 2000 ? 2000 : startYearInput - 1) : min(startYearInput, endYearInput)"
    },
    {
      "name": "endYear",
      "expr": "startYearInput == endYearInput ? (endYearInput == 2000 ? 2001 : endYearInput) : max(startYearInput, endYearInput)"
    }
  ],
  "spacing": 42,
  "config": {
    "background": "white",
    "view": {
      "stroke": null
    },
    "font": "Inter, Arial, sans-serif",
    "title": {
      "anchor": "start",
      "fontSize": 18,
      "fontWeight": "bold",
      "color": "#1F2933",
      "subtitleFontSize": 11,
      "subtitleColor": "#5F6B66",
      "offset": 8
    },
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "domainColor": "#B8C0BC",
      "tickColor": "#B8C0BC",
      "gridColor": "#E9ECEA",
      "labelColor": "#1F2933",
      "titleColor": "#1F2933"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "labelColor": "#1F2933",
      "titleColor": "#1F2933"
    }
  },
  "vconcat": [
    {
      "width": 1200,
      "height": 520,
      "title": {
        "text": "Fossil-fuel reduction by country",
        "anchor": "middle"
      },
      "projection": {
        "type": "equalEarth"
      },
      "layer": [
        {
          "data": {
            "url": "https://vega.github.io/vega-datasets/data/world-110m.json",
            "format": {
              "type": "topojson",
              "feature": "countries"
            }
          },
          "mark": {
            "type": "geoshape",
            "fill": "#F1F1F1",
            "stroke": "white",
            "strokeWidth": 0.25
          }
        },
        {
          "data": {
            "url": "https://vega.github.io/vega-datasets/data/world-110m.json",
            "format": {
              "type": "topojson",
              "feature": "countries"
            }
          },
          "transform": [
            {
              "lookup": "id",
              "from": {
                "data": {
                  "url": "../data/results/data/energy_fossil_reduction_map.csv",
                  "format": {
                    "type": "csv",
                    "parse": {
                      "iso_numeric": "number",
                      "fossil_share_energy_start": "number",
                      "fossil_share_energy_latest": "number",
                      "fossil_reduction": "number",
                      "renewables_share_energy_latest": "number",
                      "population_latest": "number",
                      "start_year": "number",
                      "latest_year": "number"
                    }
                  }
                },
                "key": "iso_numeric",
                "fields": [
                  "country",
                  "iso_code",
                  "start_year",
                  "latest_year",
                  "fossil_share_energy_start",
                  "fossil_share_energy_latest",
                  "fossil_reduction",
                  "renewables_share_energy_latest",
                  "population_latest"
                ]
              }
            },
            {
              "filter": "isValid(datum.fossil_reduction)"
            }
          ],
          "mark": {
            "type": "geoshape",
            "stroke": "white",
            "strokeWidth": 0.25
          },
          "encoding": {
            "color": {
              "field": "fossil_reduction",
              "type": "quantitative",
              "title": "Reduction (percentage points)",
              "scale": {
                "scheme": "greens"
              },
              "legend": {
                "orient": "right",
                "direction": "vertical",
                "gradientLength": 360,
                "gradientThickness": 16,
                "titleOrient": "left",
                "labelFontSize": 12,
                "titleFontSize": 12,
                "titleColor": "#1F2933",
                "labelColor": "#1F2933",
                "offset": 8
              }
            },
            "tooltip": [
              {
                "field": "country",
                "type": "nominal",
                "title": "Country"
              },
              {
                "field": "fossil_share_energy_start",
                "type": "quantitative",
                "format": ".1f",
                "title": "Fossil share in 2000 (%)"
              },
              {
                "field": "fossil_share_energy_latest",
                "type": "quantitative",
                "format": ".1f",
                "title": "Latest fossil share (%)"
              },
              {
                "field": "fossil_reduction",
                "type": "quantitative",
                "format": "+.1f",
                "title": "Reduction"
              },
              {
                "field": "renewables_share_energy_latest",
                "type": "quantitative",
                "format": ".1f",
                "title": "Latest renewables share (%)"
              }
            ]
          }
        }
      ]
    },
    {
      "hconcat": [
        {
          "width": 420,
          "height": 330,
          "title": {
            "text": "Renewable leaders",
            "subtitle": [
              "Top 10 by share"
            ],
            "anchor": "middle"
          },
          "data": {
            "url": "../data/results/data/energy_dashboard_yearly.csv",
            "format": {
              "type": "csv",
              "parse": {
                "year": "number",
                "renewables_share_energy": "number"
              }
            }
          },
          "transform": [
            {
              "filter": "datum.year == max(startYear, endYear)"
            },
            {
              "filter": "isValid(datum.renewables_share_energy)"
            },
            {
              "window": [
                {
                  "op": "rank",
                  "as": "rank"
                }
              ],
              "sort": [
                {
                  "field": "renewables_share_energy",
                  "order": "descending"
                }
              ]
            },
            {
              "filter": "datum.rank <= 10"
            },
            {
              "calculate": "0",
              "as": "zero"
            },
            {
              "calculate": "format(datum.renewables_share_energy, '.0f') + '%'",
              "as": "label"
            }
          ],
          "encoding": {
            "y": {
              "field": "country",
              "type": "nominal",
              "sort": {
                "field": "renewables_share_energy",
                "order": "descending"
              },
              "title": null,
              "axis": {
                "labels": false,
                "ticks": false,
                "domain": false
              }
            }
          },
          "layer": [
            {
              "mark": {
                "type": "text",
                "align": "left",
                "baseline": "middle",
                "fontSize": 11,
                "color": "#333333",
                "fontWeight": "normal"
              },
              "encoding": {
                "x": {
                  "value": 0
                },
                "y": {
                  "field": "country",
                  "type": "nominal",
                  "sort": {
                    "field": "renewables_share_energy",
                    "order": "descending"
                  }
                },
                "text": {
                  "field": "country"
                }
              }
            },
            {
              "mark": {
                "type": "rule",
                "strokeWidth": 1,
                "color": "#DDE5DF"
              },
              "encoding": {
                "x": {
                  "field": "zero",
                  "type": "quantitative",
                  "scale": {
                    "domain": [
                      -35,
                      90
                    ]
                  },
                  "title": null,
                  "axis": {
                    "labels": false,
                    "ticks": false,
                    "domain": false,
                    "grid": false
                  }
                },
                "x2": {
                  "field": "renewables_share_energy"
                }
              }
            },
            {
              "mark": {
                "type": "point",
                "filled": true,
                "size": 90,
                "color": "#2E7D57"
              },
              "encoding": {
                "x": {
                  "field": "renewables_share_energy",
                  "type": "quantitative"
                },
                "tooltip": [
                  {
                    "field": "country",
                    "type": "nominal",
                    "title": "Country"
                  },
                  {
                    "field": "renewables_share_energy",
                    "type": "quantitative",
                    "format": ".1f",
                    "title": "Renewables share (%)"
                  }
                ]
              }
            },
            {
              "mark": {
                "type": "text",
                "align": "left",
                "baseline": "middle",
                "dx": 8,
                "fontSize": 11,
                "color": "#2E7D57",
                "fontWeight": "normal"
              },
              "encoding": {
                "x": {
                  "field": "renewables_share_energy",
                  "type": "quantitative"
                },
                "text": {
                  "field": "label"
                }
              }
            }
          ]
        },
        {
          "width": 420,
          "height": 330,
          "title": {
            "text": "Energy mix trade off",
            "subtitle": [
              "Upper-left = cleaner energy mix."
            ],
            "anchor": "middle"
          },
          "data": {
            "url": "../data/results/data/energy_dashboard_yearly.csv",
            "format": {
              "type": "csv",
              "parse": {
                "year": "number",
                "population": "number",
                "renewables_share_energy": "number",
                "fossil_share_energy": "number"
              }
            }
          },
          "transform": [
            {
              "filter": "datum.year == max(startYear, endYear)"
            },
            {
              "calculate": "datum.is_focus_country === true || datum.is_focus_country === 'True' || datum.is_focus_country === 'true'",
              "as": "is_highlight"
            }
          ],
          "layer": [
            {
              "data": {
                "values": [
                  {
                    "x": 50
                  }
                ]
              },
              "mark": {
                "type": "rule",
                "strokeDash": [
                  2,
                  3
                ],
                "strokeWidth": 1,
                "color": "#CCD5D0",
                "opacity": 0.75
              },
              "encoding": {
                "x": {
                  "field": "x",
                  "type": "quantitative"
                }
              }
            },
            {
              "data": {
                "values": [
                  {
                    "y": 20
                  }
                ]
              },
              "mark": {
                "type": "rule",
                "strokeDash": [
                  2,
                  3
                ],
                "strokeWidth": 1,
                "color": "#CCD5D0",
                "opacity": 0.75
              },
              "encoding": {
                "y": {
                  "field": "y",
                  "type": "quantitative"
                }
              }
            },
            {
              "data": {
                "values": [
                  {
                    "x": 50,
                    "y": 72,
                    "label": "50% fossil reference"
                  }
                ]
              },
              "mark": {
                "type": "text",
                "fontSize": 10,
                "color": "#6B756F",
                "align": "left",
                "baseline": "top",
                "dx": 4
              },
              "encoding": {
                "x": {
                  "field": "x",
                  "type": "quantitative"
                },
                "y": {
                  "field": "y",
                  "type": "quantitative"
                },
                "text": {
                  "field": "label"
                }
              }
            },
            {
              "data": {
                "values": [
                  {
                    "x": 2,
                    "y": 20,
                    "label": "20% renewables reference"
                  }
                ]
              },
              "mark": {
                "type": "text",
                "fontSize": 10,
                "color": "#6B756F",
                "align": "left",
                "baseline": "bottom",
                "dy": -4
              },
              "encoding": {
                "x": {
                  "field": "x",
                  "type": "quantitative"
                },
                "y": {
                  "field": "y",
                  "type": "quantitative"
                },
                "text": {
                  "field": "label"
                }
              }
            },
            {
              "mark": {
                "type": "circle",
                "opacity": 0.38,
                "stroke": "white",
                "strokeWidth": 0.5
              },
              "encoding": {
                "x": {
                  "field": "fossil_share_energy",
                  "type": "quantitative",
                  "title": "Fossil share of primary energy (%)",
                  "scale": {
                    "domain": [
                      0,
                      100
                    ]
                  },
                  "axis": {
                    "tickCount": 6,
                    "grid": true,
                    "gridColor": "#ECECEC",
                    "domain": false,
                    "ticks": false
                  }
                },
                "y": {
                  "field": "renewables_share_energy",
                  "type": "quantitative",
                  "title": "Renewables share of primary energy (%)",
                  "scale": {
                    "domain": [
                      0,
                      75
                    ]
                  },
                  "axis": {
                    "tickCount": 5,
                    "grid": true,
                    "gridColor": "#ECECEC",
                    "domain": false,
                    "ticks": false
                  }
                },
                "size": {
                  "field": "population",
                  "type": "quantitative",
                  "scale": {
                    "range": [
                      18,
                      1200
                    ]
                  },
                  "legend": null
                },
                "color": {
                  "condition": {
                    "test": "datum.is_highlight",
                    "value": "#2E7D57"
                  },
                  "value": "#BFC5C1"
                },
                "tooltip": [
                  {
                    "field": "country",
                    "type": "nominal",
                    "title": "Country"
                  },
                  {
                    "field": "renewables_share_energy",
                    "type": "quantitative",
                    "format": ".1f",
                    "title": "Renewables share (%)"
                  },
                  {
                    "field": "fossil_share_energy",
                    "type": "quantitative",
                    "format": ".1f",
                    "title": "Fossil share (%)"
                  },
                  {
                    "field": "population",
                    "type": "quantitative",
                    "format": ",",
                    "title": "Population"
                  }
                ]
              }
            },
            {
              "transform": [
                {
                  "filter": "datum.is_highlight"
                }
              ],
              "mark": {
                "type": "circle",
                "opacity": 0.95,
                "stroke": "white",
                "strokeWidth": 1
              },
              "encoding": {
                "x": {
                  "field": "fossil_share_energy",
                  "type": "quantitative"
                },
                "y": {
                  "field": "renewables_share_energy",
                  "type": "quantitative"
                },
                "size": {
                  "field": "population",
                  "type": "quantitative",
                  "scale": {
                    "range": [
                      18,
                      1200
                    ]
                  },
                  "legend": null
                },
                "color": {
                  "value": "#2E7D57"
                },
                "tooltip": [
                  {
                    "field": "country",
                    "type": "nominal",
                    "title": "Country"
                  },
                  {
                    "field": "renewables_share_energy",
                    "type": "quantitative",
                    "format": ".1f",
                    "title": "Renewables share (%)"
                  },
                  {
                    "field": "fossil_share_energy",
                    "type": "quantitative",
                    "format": ".1f",
                    "title": "Fossil share (%)"
                  },
                  {
                    "field": "population",
                    "type": "quantitative",
                    "format": ",",
                    "title": "Population"
                  }
                ]
              }
            },
            {
              "transform": [
                {
                  "filter": "datum.is_highlight"
                }
              ],
              "mark": {
                "type": "text",
                "fontSize": 10,
                "color": "#333333",
                "fontWeight": "normal"
              },
              "encoding": {
                "x": {
                  "field": "fossil_share_energy",
                  "type": "quantitative"
                },
                "y": {
                  "field": "renewables_share_energy",
                  "type": "quantitative"
                },
                "text": {
                  "field": "country"
                },
                "dx": {
                  "value": 6
                },
                "dy": {
                  "value": -8
                },
                "align": {
                  "value": "left"
                },
                "tooltip": [
                  {
                    "field": "country",
                    "type": "nominal",
                    "title": "Country"
                  },
                  {
                    "field": "renewables_share_energy",
                    "type": "quantitative",
                    "format": ".1f",
                    "title": "Renewables share (%)"
                  },
                  {
                    "field": "fossil_share_energy",
                    "type": "quantitative",
                    "format": ".1f",
                    "title": "Fossil share (%)"
                  },
                  {
                    "field": "population",
                    "type": "quantitative",
                    "format": ",",
                    "title": "Population"
                  }
                ]
              }
            }
          ]
        },
        {
          "width": 420,
          "height": 330,
          "title": {
            "text": "Biggest gains",
            "subtitle": [
              "Largest renewable share increase"
            ],
            "anchor": "middle"
          },
          "data": {
            "url": "../data/results/data/energy_improver_pairs.csv",
            "format": {
              "type": "csv",
              "parse": {
                "start_year": "number",
                "end_year": "number",
                "renewables_share_energy_start": "number",
                "renewables_share_energy_end": "number",
                "renewables_share_energy_change": "number"
              }
            }
          },
          "transform": [
            {
              "filter": "datum.start_year == min(startYear, endYear) && datum.end_year == max(startYear, endYear)"
            },
            {
              "window": [
                {
                  "op": "rank",
                  "as": "rank"
                }
              ],
              "sort": [
                {
                  "field": "renewables_share_energy_change",
                  "order": "descending"
                }
              ]
            },
            {
              "filter": "datum.rank <= 10"
            },
            {
              "calculate": "(datum.renewables_share_energy_change >= 0 ? '+' : '') + format(datum.renewables_share_energy_change, '.0f') + ' pts'",
              "as": "change_label"
            },
            {
              "fold": [
                "renewables_share_energy_start",
                "renewables_share_energy_end"
              ],
              "as": [
                "year_type",
                "value"
              ]
            },
            {
              "calculate": "datum.year_type === 'renewables_share_energy_start' ? 'start' : 'end'",
              "as": "year_label"
            }
          ],
          "encoding": {
            "y": {
              "field": "country",
              "type": "nominal",
              "sort": {
                "field": "renewables_share_energy_change",
                "order": "descending"
              },
              "title": null,
              "axis": {
                "labels": false,
                "ticks": false,
                "domain": false,
                "labelFontWeight": "normal"
              }
            }
          },
          "layer": [
            {
              "mark": {
                "type": "text",
                "align": "left",
                "baseline": "middle",
                "fontSize": 11,
                "color": "#333333",
                "fontWeight": "normal"
              },
              "encoding": {
                "x": {
                  "value": 0
                },
                "y": {
                  "field": "country",
                  "type": "nominal",
                  "sort": {
                    "field": "renewables_share_energy_change",
                    "order": "descending"
                  }
                },
                "text": {
                  "field": "country"
                }
              }
            },
            {
              "mark": {
                "type": "rule",
                "strokeWidth": 1.2,
                "color": "#D9D9D9"
              },
              "encoding": {
                "x": {
                  "field": "renewables_share_energy_start",
                  "type": "quantitative",
                  "scale": {
                    "domain": [
                      -35,
                      65
                    ]
                  },
                  "title": null,
                  "axis": {
                    "labels": false,
                    "ticks": false,
                    "domain": false,
                    "grid": false
                  }
                },
                "x2": {
                  "field": "renewables_share_energy_end"
                }
              }
            },
            {
              "mark": {
                "type": "point",
                "filled": true,
                "size": 70
              },
              "encoding": {
                "x": {
                  "field": "value",
                  "type": "quantitative"
                },
                "color": {
                  "field": "year_label",
                  "type": "nominal",
                  "scale": {
                    "domain": [
                      "start",
                      "end"
                    ],
                    "range": [
                      "#A0A0A0",
                      "#2E7D57"
                    ]
                  },
                  "legend": null
                },
                "tooltip": [
                  {
                    "field": "country",
                    "type": "nominal",
                    "title": "Country"
                  },
                  {
                    "field": "start_year",
                    "type": "quantitative",
                    "title": "Start year",
                    "format": ".0f"
                  },
                  {
                    "field": "renewables_share_energy_start",
                    "type": "quantitative",
                    "format": ".1f",
                    "title": "Start value (%)"
                  },
                  {
                    "field": "end_year",
                    "type": "quantitative",
                    "title": "End year",
                    "format": ".0f"
                  },
                  {
                    "field": "renewables_share_energy_end",
                    "type": "quantitative",
                    "format": ".1f",
                    "title": "End value (%)"
                  },
                  {
                    "field": "renewables_share_energy_change",
                    "type": "quantitative",
                    "format": ".1f",
                    "title": "Change (pp)"
                  }
                ]
              }
            },
            {
              "mark": {
                "type": "text",
                "align": "left",
                "baseline": "middle",
                "dx": 22,
                "fontSize": 11,
                "color": "#2E7D57",
                "fontWeight": "normal"
              },
              "encoding": {
                "x": {
                  "field": "renewables_share_energy_end",
                  "type": "quantitative"
                },
                "text": {
                  "field": "change_label"
                }
              }
            }
          ]
        }
      ],
      "spacing": 30
    },
    {
      "width": 1320,
      "height": 340,
      "title": {
        "text": "Transition paths over time",
        "subtitle": [
          "Hydro leaders cluster near the top; Denmark shows rapid catch up"
        ],
        "anchor": "middle"
      },
      "data": {
        "url": "../data/results/data/energy_story_countries.csv",
        "format": {
          "type": "csv",
          "parse": {
            "year": "number",
            "clean_share_elec": "number",
            "fossil_share_elec": "number",
            "transition_gap": "number"
          }
        }
      },
      "transform": [
        {
          "filter": "datum.year >= min(startYear, endYear) && datum.year <= max(startYear, endYear)"
        },
        {
          "calculate": "datum.clean_share_elec - datum.fossil_share_elec",
          "as": "transition_gap"
        }
      ],
      "layer": [
        {
          "data": {
            "values": [
              {
                "transition_gap": 0
              }
            ]
          },
          "mark": {
            "type": "rule",
            "color": "#A0A0A0"
          },
          "encoding": {
            "y": {
              "field": "transition_gap",
              "type": "quantitative",
              "scale": {
                "domain": [
                  -100,
                  110
                ]
              },
              "axis": {
                "grid": false
              }
            }
          }
        },
        {
          "mark": {
